---
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL;
---

<nav>
    <a href={base} class="nav-brand">
        <Logo size="sm" class="nav-logo-img" ariaLabel="Skaraz Data — home" />
        <span class="nav-brand-text">Skaraz<span> </span>Data</span>
    </a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
        <a href={`${base}about`}>About</a>
        <a href={`${base}projects/case-study-raincoat`}>Case Study</a>
        <a href={`${base}blog`}>Blog</a>
        <a
            href="https://calendly.com/skaraz_data/15-minute-meeting"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-cta"
        >Book a Call</a>
    </div>
</nav>

<script>
    const toggle = document.getElementById('menu-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
        const isOpen = links?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
</script>

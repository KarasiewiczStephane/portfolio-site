---
export interface Props {
    quote: string;
    highlight?: string;
    name: string;
    role: string;
    company: string;
    logoSrc?: string;
    logoAlt?: string;
    featured?: boolean;
}

const {
    quote,
    highlight,
    name,
    role,
    company,
    logoSrc,
    logoAlt,
    featured = false,
} = Astro.props;

type QuotePart = { text: string; bold?: boolean };

let quoteParts: QuotePart[];
if (highlight && quote.includes(highlight)) {
    const idx = quote.indexOf(highlight);
    quoteParts = [
        { text: quote.slice(0, idx) },
        { text: highlight, bold: true },
        { text: quote.slice(idx + highlight.length) },
    ];
} else {
    quoteParts = [{ text: quote }];
}
---

<blockquote class:list={['testimonial', { 'testimonial--featured': featured }]}>
    <p class="testimonial__quote">
        {quoteParts.map((part) => (part.bold ? <strong>{part.text}</strong> : part.text))}
    </p>

    <footer class="testimonial__author">
        {logoSrc && (
            <img
                src={logoSrc}
                alt={logoAlt ?? ''}
                class="testimonial__logo"
                loading="lazy"
            />
        )}
        <div class="testimonial__meta">
            <span class="testimonial__name">{name}</span>
            <span class="testimonial__role">{role}</span>
            <span class="testimonial__company">{company}</span>
        </div>
    </footer>
</blockquote>

<style>
    .testimonial {
        --t-bg: #ffffff;
        --t-border: rgba(15, 27, 44, 0.1);
        --t-border-hover: rgba(15, 27, 44, 0.22);
        --t-text: #0f1b2c;
        --t-text-soft: #4a5a70;
        --t-text-muted: #7a8aa0;
        --t-accent: #d85a30;
        --t-quote-mark: rgba(15, 27, 44, 0.12);

        position: relative;
        display: flex;
        flex-direction: column;
        background: var(--t-bg);
        color: var(--t-text);
        border: 1px solid var(--t-border);
        border-radius: 14px;
        padding: 2.5rem 1.9rem 1.9rem;
        margin: 0;
        box-shadow: 0 1px 2px rgba(15, 27, 44, 0.04);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .testimonial::before {
        content: '\201C';
        position: absolute;
        top: 0.4rem;
        left: 1.25rem;
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 4.5rem;
        line-height: 1;
        color: var(--t-quote-mark);
        pointer-events: none;
    }

    .testimonial:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(15, 27, 44, 0.08);
        border-color: var(--t-border-hover);
    }

    .testimonial--featured {
        border: 1px solid rgba(216, 90, 48, 0.5);
        box-shadow: 0 4px 18px rgba(216, 90, 48, 0.08);
    }

    .testimonial--featured::before {
        color: var(--t-accent);
        opacity: 0.55;
    }

    .testimonial--featured:hover {
        box-shadow: 0 16px 36px rgba(216, 90, 48, 0.14);
    }

    .testimonial__quote {
        font-size: 1rem;
        line-height: 1.65;
        color: var(--t-text);
        font-style: italic;
        margin: 0 0 1.75rem;
        flex: 1;
    }

    .testimonial__quote strong {
        font-weight: 600;
        font-style: normal;
        color: var(--t-text);
    }

    .testimonial__author {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--t-border);
        margin-top: auto;
    }

    .testimonial__logo {
        flex: 0 0 auto;
        width: 48px;
        height: 48px;
        object-fit: contain;
        border-radius: 6px;
        background: #ffffff;
    }

    .testimonial__meta {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        line-height: 1.35;
        min-width: 0;
    }

    .testimonial__name {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--t-text);
    }

    .testimonial__role {
        font-size: 0.82rem;
        color: var(--t-text-soft);
    }

    .testimonial__company {
        font-size: 0.78rem;
        color: var(--t-text-muted);
        letter-spacing: 0.02em;
    }
</style>

    "inLanguage": "en",
    "datePublished": "2026-05-20",
    "author": {
        "@type": "Person",
        "name": "Stéphane Karasiewicz",
        "url": "https://skarazdata.com"
    },
    "publisher": {
        "@type": "Organization",

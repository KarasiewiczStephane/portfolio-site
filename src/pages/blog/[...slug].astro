---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blogs');
    return posts.map(p => ({
        params: { slug: p.slug },
        props: { post: p },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL;
const readingTime = post.data.readingTimeMinutes || Math.ceil(post.body.split(' ').length / 200);
const canonicalUrl = new URL(`blog/${post.slug}`, "https://skarazdata.com").href;

const blogPostingJsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.publishedDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.publishedDate).toISOString(),
    "author": {
        "@type": "Person",
        "name": post.data.author,
        "url": "https://skarazdata.com",
    },
    "publisher": {
        "@type": "Organization",
        "name": "Skaraz Data",
        "url": "https://skarazdata.com",
    },
    "mainEntityOfPage": canonicalUrl,
    "wordCount": post.body.split(' ').length,
    "keywords": post.data.tags.join(', '),
};
---

<BaseLayout
    title={`${post.data.title} — Skaraz Data`}
    description={post.data.description}
    ogType="article"
    jsonLd={blogPostingJsonLd}
    articleMeta={{
        publishedTime: post.data.publishedDate.toISOString(),
        modifiedTime: post.data.updatedDate?.toISOString(),
        author: post.data.author,
        tags: post.data.tags,
    }}
>
    <article class="blog-post">
        <div class="section-container">
            <a href={`${base}blog`} class="back-link">&larr; Back to Blog</a>

            <header class="post-header">
                <h1>{post.data.title}</h1>
                <div class="post-meta">
                    <time datetime={post.data.publishedDate.toISOString()}>
                        {post.data.publishedDate.toLocaleDateString('en-US', {
                            year: 'numeric', month: 'long', day: 'numeric'
                        })}
                    </time>
                    <span class="post-reading-time">{readingTime} min read</span>
                    <span class="post-author">by {post.data.author}</span>
                </div>
                {post.data.tags && (
                    <div class="post-tags">
                        {post.data.tags.map(tag => (
                            <span class="post-tag">{tag}</span>
                        ))}
                    </div>
                )}
            </header>

            <div class="post-content">
                <Content />
            </div>

            <footer class="post-footer">
                <div class="post-cta">
                    <h3>Need climate risk data infrastructure?</h3>
                    <p>I build satellite data pipelines, risk scoring APIs, and interactive dashboards for climate and environmental analytics.</p>
                    <a href="https://calendly.com/skaraz_data/15-minute-meeting" target="_blank" rel="noopener noreferrer" class="btn-primary">Book a Free Discovery Call</a>
                </div>
            </footer>
        </div>
    </article>
</BaseLayout>

<style>
/* =====================================================================
   BLOG POST LAYOUT
   Constrain the reading column to 760px; the outer article takes full
   width so the header and CTA can breathe differently if needed later.
   ===================================================================== */

.blog-post {
    padding: 8rem 1.5rem 5rem;
}

/* Re-use section-container from global but constrain to reading width */
.blog-post .section-container {
    max-width: 760px;
}

/* =====================================================================
   BACK NAVIGATION
   Matches the nav link style: small, muted, reveals accent on hover.
   Stripe and Linear both use this "fade to accent" pattern rather than
   a permanent accent color on navigation chrome.
   ===================================================================== */

.back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8125rem;          /* 13px — matches Stripe detail size */
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
}
.back-link:hover {
    color: var(--accent);
}

/* =====================================================================
   POST HEADER
   Title uses DM Serif Display at a larger clamp range than before.
   Stripe uses 42–56px for post titles; Linear uses ~48px at desktop.
   We land at 42px max which suits a 760px column without overwhelming.

   Key changes from research:
   - letter-spacing: -0.02em on display headings (Stripe: -.25px at 56px
     ≈ -.004em; overreacted uses -0.02em; leerob uses --tracking-tight
     which is -.025em). We use -0.02em as a safe middle.
   - line-height: 1.15 → 1.12 for tighter display type at large sizes
   - margin-bottom between title and meta increased to 1.5rem for air
   ===================================================================== */

.post-header {
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
}

.post-header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.875rem, 4vw, 2.625rem); /* 30px → 42px */
    font-weight: 400;                           /* DM Serif is already optical heavy at 400 */
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    text-wrap: pretty;                          /* prevents single-word orphan lines */
}

/* =====================================================================
   POST META ROW
   Reduced font size to 0.8125rem (13px) — same as Stripe's meta row.
   Separator dots between items using ::before pseudo-elements give a
   cleaner look than large gap spacing (used by Linear, Vercel, Stripe).
   ===================================================================== */

.post-meta {
    display: flex;
    align-items: center;
    gap: 0;                         /* gaps handled by separator pseudo-elements */
    font-size: 0.8125rem;           /* 13px */
    color: var(--text-muted);
    flex-wrap: wrap;
    row-gap: 0.5rem;
}

.post-meta > * + *::before {
    content: '·';
    margin: 0 0.6rem;
    opacity: 0.4;
}

.post-meta time {
    color: var(--text-secondary);
}

.post-reading-time {
    /* Removed teal badge — too noisy next to the teal tag pills below.
       Kent C. Dodds and Linear both use plain muted text for reading time. */
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
}

.post-author {
    color: var(--text-muted);
}

/* =====================================================================
   TAGS
   Kept as pills but reduced visual weight. The border replaces the
   background fill — Vercel and Linear both use outlined pills in
   muted colors for taxonomy tags rather than filled accent ones.
   ===================================================================== */

.post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
}

.post-tag {
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.65rem;
    border-radius: 100px;           /* fully rounded — matches Stripe/Vercel pill style */
    font-size: 0.75rem;             /* 12px */
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: border-color 0.2s, color 0.2s;
}
.post-tag:hover {
    color: var(--accent);
    border-color: rgba(62, 207, 180, 0.25);
}

/* =====================================================================
   READING BODY
   Core typography changes based on research findings:

   font-size: 1.05rem → 1.0625rem (17px)
   Why: Stripe uses 18px for body at 600px+ breakpoint. leerob uses
   --text-lg = 1.125rem (18px). Kent C. Dodds uses 1.125rem. Josh Comeau
   uses 1.125rem. 17px (1.0625rem) is our compromise — it's larger than
   the current 1.05rem but respects the 760px max-width column which is
   already narrower than most of the reference sites.

   line-height: 1.8 → 1.75
   Why: 1.8 is slightly loose for 17px text. Stripe uses 28px/18px ≈ 1.556.
   Kent C. Dodds and Josh Comeau both settle around 1.6–1.65 in their
   prose CSS. leerob uses --leading-relaxed: 1.625. We use 1.75 because
   DM Serif Display headings interrupt body flow and need slightly more air
   for the eye to re-lock onto body text after a heading.

   color: var(--text-secondary) → kept; #8B97A8 at 17px passes WCAG AA
   on #0B0F14 (contrast ratio ~5.2:1).

   -webkit-font-smoothing: antialiased
   All reference sites use this on dark backgrounds.
   ===================================================================== */

.post-content {
    max-width: 760px;
    font-size: 1.0625rem;           /* 17px */
    line-height: 1.75;
    color: var(--text-secondary);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

/* =====================================================================
   HEADINGS INSIDE CONTENT
   H2: DM Serif Display, sized up from 1.5rem to 1.625rem (26px).
   Stripe uses 26px/36px for H3 equivalents. overreacted uses 1.5625rem
   for H2/H3 at mobile, 1.875rem at desktop.

   Margins follow the "double the bottom, triple the top" rule from
   Robert Bringhurst: heading top margin ≈ 3× bottom margin. This
   creates visual grouping — the heading belongs to the section below it.

   H2 top: 3.5rem (56px), bottom: 1rem (16px)
   H3 top: 2.5rem (40px), bottom: 0.75rem (12px)
   H4 top: 2rem (32px), bottom: 0.5rem (8px)

   These values come from cross-referencing Kent C. Dodds' prose CSS
   (h2: margin-top 5rem, margin-bottom 2.5rem) scaled down proportionally
   for our narrower, shorter-post use case.
   ===================================================================== */

.post-content :global(h2) {
    font-family: 'DM Serif Display', serif;
    font-size: 1.625rem;            /* 26px */
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    margin: 3.5rem 0 1rem;
}

.post-content :global(h3) {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;            /* 18px */
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--text-primary);
    margin: 2.5rem 0 0.75rem;
}

.post-content :global(h4) {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;                /* 16px */
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--text-primary);
    margin: 2rem 0 0.5rem;
}

/* Prevent a heading from sitting at the very top of post-content
   (when it's the first child). The section-container padding already
   handles spacing above, so remove the extra top margin. */
.post-content > :global(h2:first-child),
.post-content > :global(h3:first-child),
.post-content > :global(h4:first-child) {
    margin-top: 0;
}

/* =====================================================================
   PARAGRAPHS
   Bottom margin increased from 1.2rem to 1.5rem.
   This is the single most impactful change for long-form readability.
   Stripe uses ~20px paragraph gap. Kent C. Dodds uses 2rem.
   1.5rem (24px) at 17px body text = ~1.4× the line-height, which is
   the correct optical gap to signal "new thought" without breaking flow.
   ===================================================================== */

.post-content :global(p) {
    margin-bottom: 1.5rem;
}

/* Tighten up paragraphs that immediately follow a heading — they've
   already been separated by the heading's own bottom margin. */
.post-content :global(h2 + p),
.post-content :global(h3 + p),
.post-content :global(h4 + p) {
    margin-top: 0;
}

/* =====================================================================
   LINKS
   Research finding: the best-reading blogs use a layered approach.
   - Base: no decoration, teal color (already done — correct)
   - Underline: text-decoration-line with text-underline-offset
     (not border-bottom) — this is what Stripe, Kent C. Dodds, and
     Josh Comeau all do. CSS text-decoration gives better rendering at
     subpixel levels, respects descenders, and doesn't affect line-height.
   - text-decoration-color at 35% opacity for the resting state
   - Hover: solid decoration at full accent color + subtle brightness

   text-underline-offset: 3px — the standard value used across all
   reference sites. It positions the line just below the baseline,
   creating clear separation from descenders on letters like g, p, y.
   ===================================================================== */

.post-content :global(a),
.post-content :global(a:link),
.post-content :global(a:visited),
.post-content :global(a:active) {
    color: #3ECFB4 !important;
    text-decoration: underline;
    text-decoration-color: rgba(62, 207, 180, 0.3);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
}
.post-content :global(a:hover) {
    color: #3ECFB4 !important;
    text-decoration-color: #3ECFB4;
}

/* =====================================================================
   LISTS
   Three changes from current state:
   1. Left margin reduced from 1.5rem to 1.25rem — the browser default
      padding-left on ul/ol handles the bullet indent; the margin is just
      for visual indentation from the text column edge.
   2. Bottom margin increased to 1.5rem to match paragraph rhythm.
   3. li line-height explicitly set to 1.65 — slightly tighter than body
      prose because list items are shorter chunks. Kent C. Dodds uses
      this same stepped approach in their prose CSS.
   ===================================================================== */

.post-content :global(ul),
.post-content :global(ol) {
    margin: 0.5rem 0 1.5rem 1.25rem;
    padding-left: 0.25rem;
}

.post-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.65;
}

/* Nested lists tighten up */
.post-content :global(li > ul),
.post-content :global(li > ol) {
    margin-top: 0.4rem;
    margin-bottom: 0.4rem;
}

/* Strong inside lists — Stripe sets font-weight: semibold and title color
   for strong text (.BlogPost__body strong). This helps bold terms inside
   bullet lists pop against the muted body text color. */
.post-content :global(strong) {
    font-weight: 600;
    color: var(--text-primary);
}

/* =====================================================================
   INLINE CODE
   Changes from current:
   - Background: rgba(255,255,255,0.06) instead of var(--bg-card).
     This creates less contrast jump — inline code on a dark background
     should feel "embedded" not "boxed". Josh Comeau uses this approach
     with a very subtle tint.
   - Color: var(--accent) kept — teal on dark is readable and distinctive
   - border: 1px solid rgba(255,255,255,0.08) — a subtle border that
     defines the pill shape without heavy background. Linear does this.
   - font-size: 0.875em (relative to parent) — standard across all refs
   - padding: adjusted to 0.125rem 0.4rem — the extra top/bottom padding
     was causing inline code to shift the line-height optically.
   ===================================================================== */

.post-content :global(:not(pre) > code) {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.125em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    color: var(--accent);
    white-space: nowrap;
}

/* =====================================================================
   CODE BLOCKS (pre)
   Research findings from Josh Comeau and Kent C. Dodds:

   1. Background: #0D1117 — this is GitHub's dark code background and is
      used widely because it has more contrast with #0B0F14 than
      var(--bg-card) (#161E28). The difference is subtle but meaningful:
      code blocks need to read as "separate environment" from prose.

   2. Border: 1px solid rgba(255,255,255,0.06) — kept subtle.
      Josh Comeau adds an additional outline on dark mode for visibility:
      outline: 1px solid var(--color-content-outline). We replicate with
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.07).

   3. border-radius: 10px — up from 8px. Matches Stripe (8px) and
      overreacted (.5rem = 8px). Josh Comeau uses 6px inside sibling
      containers. We stay at 10px for consistency with card radius.

   4. padding: 1.375rem 1.5rem — wider than current 1.2rem. Gives the
      code breathing room. Stripe uses ~1rem padding for code blocks.
      Josh Comeau's full-bleed blocks use viewport padding (~24px).

   5. Line numbers: not added here since Astro's default highlighter
      doesn't inject them without a plugin. This keeps the template
      dependency-free.

   6. font-size: 0.8125rem (13px) — Kent C. Dodds uses 15px (0.9375rem)
      in their .b1btlj5u context. Stripe uses 15px. Josh Comeau's code
      snippets use var(--code-font-size,1rem) inside scrollable blocks.
      0.8125rem is a safe default for 760px column width — 80 chars at
      this size fits without horizontal scroll on most code.

   7. tab-size: 2 — consistent with how most modern editors display code
      in web contexts.
   ===================================================================== */

.post-content :global(pre) {
    background: #0D1117;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    padding: 1.375rem 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    tab-size: 2;
    -webkit-overflow-scrolling: touch;          /* smooth scroll on iOS */
}

/* Language label — shows which language the block is written in.
   Inspired by how Stripe labels code blocks in their docs.
   Requires a data-language attribute on the <pre> tag, which Astro's
   built-in Shiki/Prism highlighter adds automatically. */
.post-content :global(pre[data-language])::before {
    content: attr(data-language);
    display: block;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.6875rem;           /* 11px */
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    opacity: 0.6;
    margin-bottom: 0.875rem;
}

.post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;           /* 13px */
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    line-height: 1.7;               /* slightly looser than prose — code needs vertical air */
    color: #d6deeb;                 /* Night Owl theme base text color — used by Kent C. Dodds */
    white-space: pre;
}

/* Scrollbar styling for code blocks on Webkit — dark, minimal */
.post-content :global(pre)::-webkit-scrollbar {
    height: 4px;
}
.post-content :global(pre)::-webkit-scrollbar-track {
    background: transparent;
}
.post-content :global(pre)::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.12);
    border-radius: 2px;
}

/* =====================================================================
   BLOCKQUOTES
   This is the biggest visual upgrade. Current: 3px left border, italic.

   Research finding: The best tech blogs treat blockquotes in two ways:
   a) Pull quote style: large, centered, no border (Stripe, Linear)
   b) Aside/note style: background tint + left border (Kent C. Dodds,
      Josh Comeau, overreacted)

   For a data science blog, blockquotes are almost always used for
   key findings or important callouts — so we use the "aside" style from
   Kent C. Dodds: a subtle tinted background with a solid left border.

   Kent C. Dodds: blockquote { border-radius: .5rem; padding: 2rem;
                  font-weight: 400; border: none; }
   Their dark prose: { color: var(--color-slate-500);
                       background-color: var(--color-gray-800); }

   Our version adapts to the teal accent and dark palette:
   - Background: rgba(62, 207, 180, 0.05) — teal tint, very subtle
   - Left border: 3px → 4px, solid var(--accent)
   - border-radius on right corners only: 0 8px 8px 0
   - padding: 1.25rem 1.5rem (top/bottom, left/right)
   - Remove italic — data citations don't read well in italic
   - font-size: 1rem (slightly smaller than body) to signal it's a quote
   - Nested paragraphs remove their own bottom margin
   ===================================================================== */

.post-content :global(blockquote) {
    border-left: 4px solid var(--accent);
    border-radius: 0 8px 8px 0;
    background: rgba(62, 207, 180, 0.05);
    padding: 1.125rem 1.5rem;
    margin: 2rem 0;
    color: var(--text-secondary);
    font-style: normal;             /* removed italic — better for data citations */
    font-size: 1rem;
}

.post-content :global(blockquote p) {
    margin-bottom: 0;
    line-height: 1.7;
}

.post-content :global(blockquote p + p) {
    margin-top: 0.75rem;
}

/* Citation line inside blockquote (e.g., — Source Name) */
.post-content :global(blockquote cite),
.post-content :global(blockquote footer) {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-style: normal;
}

/* =====================================================================
   IMAGES
   Three improvements from research:

   1. Display: block with margin: auto — images should always be block-
      level in prose, centered horizontally. Current style relies on the
      parent flex/block context.

   2. box-shadow: layered shadow to lift the image off the dark background.
      Stripe uses box-shadow on images. Josh Comeau uses border + shadow.
      We use: 0 2px 8px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.05)
      The inner ring border replaces an explicit border and scales with
      the image's border-radius.

   3. Caption support: img + em immediately after (markdown convention for
      captions when the alt text is written as italic text after the image)
      gets styled as a proper caption. Vercel and Stripe both have styled
      caption text below images.

   4. margin: 2.5rem 0 — increased from 1.5rem. Images need more vertical
      air in long-form prose to visually separate from surrounding paragraphs.
   ===================================================================== */

.post-content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 2.5rem auto;
    box-shadow:
        0 2px 8px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(255, 255, 255, 0.05);
}

/* Image captions: markdown generates <p><img><br><em>caption</em></p>
   or sometimes <p><img></p><p><em>caption immediately after</em></p>.
   Target the em that directly follows an image inside the same p. */
.post-content :global(img + br + em),
.post-content :global(p:has(img) + p > em:only-child) {
    display: block;
    text-align: center;
    font-size: 0.8125rem;           /* 13px */
    font-style: normal;
    color: var(--text-muted);
    margin-top: -1.5rem;            /* pull up into the image's bottom margin */
    margin-bottom: 2rem;
    letter-spacing: 0.01em;
}

/* =====================================================================
   HORIZONTAL RULE
   Current: browser default (not styled).
   Stripe and Linear use a very subtle 1px rule at ~20% opacity.
   We add it for section breaks in long-form posts.
   ===================================================================== */

.post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
    opacity: 0.8;
}

/* =====================================================================
   TABLES
   Not in the current template but likely to appear in data science posts.
   Based on Stripe's table style: clean borders, alternating row tint,
   header row differentiated by font-weight and color.
   ===================================================================== */

.post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;            /* 14px */
    line-height: 1.5;
    margin: 2rem 0;
    overflow-x: auto;
    display: block;
}

.post-content :global(thead th) {
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.625rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.post-content :global(tbody td) {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
    vertical-align: top;
}

.post-content :global(tbody tr:last-child td) {
    border-bottom: none;
}

.post-content :global(tbody tr:hover td) {
    background: rgba(255, 255, 255, 0.02);
}

/* =====================================================================
   POST FOOTER
   Increased top margin for better separation from the article body.
   ===================================================================== */

.post-footer {
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
}

/* =====================================================================
   CTA BLOCK
   Subtle upgrade: the left accent bar (used by Stripe's CopyBody
   --anchored pattern) signals this is an action block. The teal bar
   replaces the plain border approach. max-width set to full column
   width (760px is already the content constraint).
   ===================================================================== */

.post-cta {
    position: relative;
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.07);

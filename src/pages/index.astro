---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkedInDMButton from '../components/LinkedInDMButton.astro';
import TrustLogos from '../components/TrustLogos.astro';
import OfferTier from '../components/OfferTier.astro';
import Testimonial from '../components/Testimonial.astro';

const base = import.meta.env.BASE_URL;

// JSON-LD aligned with the Climate Pipeline Partner positioning.
const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Person",
            "name": "Stéphane Karasiewicz",
            "url": "https://skarazdata.com",
            "image": "https://skarazdata.com/portrait.jpg",
            "jobTitle": "Climate Pipeline Partner · Senior Data Engineer for Parametric Insurance",
            "worksFor": { "@type": "Organization", "name": "Skaraz Data" },
            "alumniOf": { "@type": "EducationalOrganization", "name": "Université de Lille" },
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Outreau",
                "addressRegion": "Hauts-de-France",
                "addressCountry": "FR"
            },
            "knowsAbout": [
                "Climate Risk Modeling",
                "Parametric Insurance",
                "Satellite Remote Sensing",
                "Data Engineering",
                "Production Data Pipelines",
                "Geospatial Analysis",
                "Python"
            ],
            "sameAs": [
                "https://www.linkedin.com/in/stephane-karasiewicz",
                "https://github.com/KarasiewiczStephane",
                "https://www.researchgate.net/profile/Stephane_Karasiewicz"
            ]
        },
        {
            "@type": "ProfessionalService",
            "name": "Skaraz Data",
            "url": "https://skarazdata.com",
            "image": "https://skarazdata.com/og-image.png",
            "description": "Senior data engineering for parametric insurance. Climate scoring pipelines: audit, build, partner. Bridging climate science and DevOps.",
            "provider": { "@type": "Person", "name": "Stéphane Karasiewicz" },
            "areaServed": "Worldwide",
            "serviceType": [
                "Climate data engineering",
                "Parametric insurance consulting",
                "Production data pipelines",
                "Satellite & reanalysis data integration"
            ],
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Outreau",
                "addressRegion": "Hauts-de-France",
                "addressCountry": "FR"
            }
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "What is a Climate Pipeline Discovery and how is it different from a regular consulting call?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "A Climate Pipeline Discovery is a fixed 2-week paid engagement (€5-7k). I audit your existing climate scoring pipeline, map risks and duplication, and deliver a 10-15 page technical note with a scoped remediation plan. It’s the entry point for clients who want to commit budget seriously and avoid a fuzzy consulting call."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do you write original climate models from scratch?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "No. I work with the climate scientists already on your team. I challenge their model choices through comparative studies and I industrialize the models they ship — turning prototypes into reliable, modular production pipelines."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Is there a guarantee on the code you deliver?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes — Code Quality Guarantee. Any major bug in production on code I shipped, within 30 days of handover, I fix for free. No questions. Major bug = any malfunction preventing the pipeline from producing expected outputs, or producing reproducibly incorrect outputs."
                    }
                }
            ]
        }
    ]
};
---

<BaseLayout
    title="Skaraz Data — Climate Pipeline Partner for parametric insurance"
    description="Senior data engineering for parametric insurance. Audit, build, partner. Bridging climate science and DevOps."
    ogDescription="Senior data engineering for parametric insurance. Audit, build, partner."
    ogType="website"
    jsonLd={jsonLd}
>
    <div class="page-light">
    <!-- SECTION 1 — HERO -->
    <section class="hero" aria-labelledby="hero-title">
        <div class="hero__inner">
            <div class="hero__content">
                <div class="hero__badge">Available · 2-3 new engagements per quarter</div>
                <h1 id="hero-title">
                    Ship your next climate peril in 8 to 16 weeks — <em>without recruiting in-house.</em>
                </h1>
                <p class="hero__subtitle">
                    I’m the senior data engineer parametric insurers call when their climate scoring pipelines need to bridge climate science and DevOps — without recruiting a €120k/year hire.
                </p>
                <p class="hero__credibility">
                    Ex-Raincoat · 10+ countries · 15+ years satellite &amp; reanalysis · PhD
                </p>
                <div class="hero__cta">
                    <LinkedInDMButton variant="primary" />
                    <a
                        class="hero__cta-secondary"
                        href="https://calendly.com/skaraz_data/15-minute-meeting"
                        target="_blank"
                        rel="noopener noreferrer"
                    >Book a Discovery Call <span aria-hidden="true">→</span></a>
                </div>
            </div>
            <div class="hero__visual">
                <img
                    src={`${base}portrait.jpg`}
                    alt="Stéphane Karasiewicz"
                    class="hero__portrait"
                    loading="eager"
                    fetchpriority="high"
                    width="320"
                    height="320"
                />
            </div>
        </div>
    </section>

    <!-- SECTION 2 — TRUST BAR -->
    <TrustLogos />

    <!-- SECTION 3 — PROBLEM -->
    <section class="problem" aria-labelledby="problem-title">
        <div class="problem__inner">
            <h2 id="problem-title">You’ve shipped one peril. The next three are 9 months out.</h2>
            <div class="problem__body">
                <p>Your data scientists prototyped climate models that work. Your DevOps team runs Kubernetes for the product. <strong>Nobody in the team bridges the two</strong> — and every new peril takes 6 months instead of 6 weeks.</p>
                <p>This is what I see in most parametric insurtechs I talk to: climate scoring pipelines built fast, then bolted together. Code duplicated between perils. Datasets that quietly change calibration in the middle of the night. New geographies that look like a new project every time, not a configuration change.</p>
                <p>The board refuses a new full-time hire at €120k+/year for what they perceive as a punctual need. But the next three deals depend on shipping that next peril before the next renewal cycle.</p>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — SOLUTION -->
    <section class="solution" aria-labelledby="solution-title">
        <div class="solution__inner">
            <h2 id="solution-title">I close that gap.</h2>

            <div class="solution__body">
                <p>For the past 2 years at Raincoat, I built and operated production climate pipelines across 10+ countries — drought, heat stress, precipitation, water balance. I created pipelines from scratch, designed a modular architecture, and ran the whole thing as dev/ops at the end of my contract.</p>
                <p>Before that: 15+ years in satellite remote sensing at IFREMER. PhD in Marine Ecology. 6 peer-reviewed publications. 2 CRAN R packages.</p>
                <p><strong>I’m the senior who can sit between your climate scientists and your DevOps team</strong> — challenge model choices with comparative studies, ship production code that won’t wake your team at 3am, build the operational dashboards your team actually uses, and document everything so you can run new perils without me.</p>
            </div>

            <div class="solution__pillars">
                <article class="pillar">
                    <svg class="pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 10a7.31 7.31 0 0 0 10 10Z"/>
                        <path d="m9 15 3-3"/>
                        <path d="M17 13a6 6 0 0 0-6-6"/>
                        <path d="M21 13A10 10 0 0 0 11 3"/>
                    </svg>
                    <h3 class="pillar__title">Climate Science</h3>
                    <p class="pillar__body">15+ years in satellite remote sensing. Production experience with CHIRPS, IMERG, ERA5-Land, Copernicus, MERRA-2.</p>
                </article>

                <article class="pillar">
                    <svg class="pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect width="20" height="8" x="2" y="2" rx="2" ry="2"/>
                        <rect width="20" height="8" x="2" y="14" rx="2" ry="2"/>
                        <line x1="6" x2="6.01" y1="6" y2="6"/>
                        <line x1="6" x2="6.01" y1="18" y2="18"/>
                    </svg>
                    <h3 class="pillar__title">DevOps</h3>
                    <p class="pillar__body">2 years operating production climate pipelines at Raincoat. Created 2 pipelines from scratch. Modular architecture proposal.</p>
                </article>

                <article class="pillar">
                    <svg class="pillar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                    </svg>
                    <h3 class="pillar__title">Scientific Dialogue</h3>
                    <p class="pillar__body">PhD in Marine Ecology. 6 peer-reviewed papers. 2 CRAN packages. I challenge model choices through comparative studies.</p>
                </article>
            </div>
        </div>
    </section>

    <!-- SECTION 5 — OFFER -->
    <section class="offer" aria-labelledby="offer-title">
        <div class="offer__inner">
            <h2 id="offer-title">Three ways to work together</h2>

            <div class="offer__grid">
                <OfferTier
                    number="1"
                    title="Climate Pipeline Discovery"
                    price="€5-7k"
                    duration="2 weeks"
                    summary="Full audit of your existing pipeline, risk mapping, scoped remediation plan."
                    bullets={[
                        "10-15 page technical note",
                        "Risk mapping of duplication, fragility, calibration drift",
                        "Datasets & scientific methodology audit",
                        "Production readiness assessment",
                        "Scoped remediation plan with budget & timeline",
                        "2 debrief calls",
                    ]}
                    ctaLabel="Book Discovery"
                    ctaHref="https://calendly.com/skaraz_data/15-minute-meeting"
                />

                <OfferTier
                    number="2"
                    title="Climate Pipeline Partner"
                    price="€25-50k"
                    duration="8 to 16 weeks"
                    summary="Build from scratch or refactor toward modular architecture. Integrate with existing infra. Train your team to run it without me."
                    bullets={[
                        "Build new pipeline or refactor existing one",
                        "Modular architecture, multi-peril, multi-geography",
                        "Operational dashboards",
                        "Scientific dataset review",
                        "Documentation & team training",
                        "4 follow-up sessions (months 1, 3, 6, 12)",
                    ]}
                    ctaLabel="Talk to me"
                    ctaHref="https://calendly.com/skaraz_data/15-minute-meeting"
                    featured={true}
                />

                <OfferTier
                    number="3"
                    title="Retainer Partner"
                    price="€2-4k/month"
                    duration="6 to 12 months"
                    summary="Ongoing support for evolutions, new perils, new geographies."
                    bullets={[
                        "2 to 4 days per month guaranteed",
                        "Priority access for new perils & geographies",
                        "Shared Slack with <72h response time",
                        "Monthly strategic session (60 min)",
                        "Quarterly architecture review",
                        "On-demand work on next perils & geographies",
                    ]}
                    ctaLabel="Discuss retainer"
                    ctaHref="https://calendly.com/skaraz_data/15-minute-meeting"
                />
            </div>
        </div>
    </section>

    <!-- SECTION 6 — GUARANTEE -->
    <section class="guarantee" aria-labelledby="guarantee-title">
        <div class="guarantee__inner">
            <h2 id="guarantee-title">Code Quality Guarantee</h2>
            <p class="guarantee__statement">
                Any major bug in production on code I shipped, within 30 days of handover — I fix it for free. No questions.
            </p>
            <p class="guarantee__definition">
                Major bug = any malfunction preventing the pipeline from producing expected outputs, or producing reproducibly incorrect outputs.
            </p>
        </div>
    </section>

    <!-- SECTION 7 — TESTIMONIALS -->
    <section class="testimonials" aria-labelledby="testimonials-title">
        <div class="testimonials__inner">
            <h2 id="testimonials-title">What clients say</h2>

            <div class="testimonials__grid">
                <Testimonial
                    quote="Steph is a seriously talented engineer with a rare combination of skills. He’s just as comfortable building scientific algorithms and doing deep data analysis as he is shipping polished frontend dashboards — and he does all of it at a high level. What stood out most was how independently he operated: you could hand him a complex project and trust him to run with it, communicate clearly along the way, and deliver something that genuinely moved the needle for the company. I’d recommend him to anyone in a heartbeat."
                    highlight="rare combination of skills"
                    name="Jan Paral"
                    role="Head of R&D and Co-Founder"
                    company="Raincoat LLC"
                    logoSrc="/raincoat-logo.png"
                    logoAlt="Raincoat LLC — Climate risk technology"
                    featured={true}
                />

                <Testimonial
                    quote="His coding skills are unparalleled, producing efficient and well-documented codes. His ability to translate our needs is exemplary, and he excels in proposing innovative solutions that go beyond the initial objectives. Stéphane embodies excellence and will be an invaluable asset to any organization."
                    name="Kelig Mahé"
                    role="Head of Unit, Fisheries Resources — Channel & North Sea"
                    company="IFREMER"
                    logoSrc="/ifremer-logo.png"
                    logoAlt="IFREMER — French Institute for Ocean Science"
                />

                <Testimonial
                    quote="I worked with Stéphane at the beginning of my PhD, and I am still grateful — without his recommendations I would work and troubleshoot much less efficiently. He always takes time to explain, and never loses his sense of humor even after the nth error message."
                    name="Carolin Neven"
                    role="Ph.D. Student"
                    company="IFREMER"
                    logoSrc="/ifremer-logo.png"
                    logoAlt="IFREMER — French Institute for Ocean Science"
                />
            </div>
        </div>
    </section>

    <!-- SECTION 8 — FINAL CTA -->
    <section class="final-cta" aria-labelledby="final-cta-title">
        <div class="final-cta__inner">
            <h2 id="final-cta-title">Ready to ship that next peril?</h2>
            <p class="final-cta__intro">Two ways to start:</p>

            <div class="final-cta__options">
                <div class="final-cta__option">
                    <h3>1. Get the free Reality Check PDF</h3>
                    <p>5 lessons from industrializing pipelines across 10+ countries, plus the 12-point checklist I use on every mission. No call, no pitch — just useful content.</p>
                    <LinkedInDMButton variant="primary" label="Send “reality” on LinkedIn →" />
                </div>

                <div class="final-cta__option">
                    <h3>2. Book a Discovery Call</h3>
                    <p>15 min, free, to see if a fixed Discovery mission (€5-7k, 2 weeks) makes sense for your context.</p>
                    <a
                        class="final-cta__secondary"
                        href="https://calendly.com/skaraz_data/15-minute-meeting"
                        target="_blank"
                        rel="noopener noreferrer"
                    >Book a Call <span aria-hidden="true">→</span></a>
                </div>
            </div>
        </div>
    </section>

    </div><!-- /.page-light -->
</BaseLayout>

<style>
    /* =========================================================
       PAGE WRAPPER — interim light-theme container.
       Will be removed in Étape 6 when global.css is rewritten.
       ========================================================= */
    .page-light {
        background: #ffffff;
        color: #0f1b2c;
    }

    /* =========================================================
       SECTION 1 — HERO
       ========================================================= */
    .hero {
        background: #ffffff;
        /* Override interim global.css rules that still apply:
           min-height: 100vh + display:flex + align-items:center
           force the hero to be 1 viewport tall and vertically center its
           content. Will be cleaned up in Étape 6 (global.css refonte). */
        min-height: auto;
        display: block;
        padding: 6rem 2rem 5rem;
        position: relative;
    }

    .hero__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
    }

    @media (min-width: 960px) {
        .hero__inner {
            grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
            gap: 4rem;
        }
    }

    .hero__content {
        min-width: 0;
    }

    .hero__badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #d85a30;
        background: rgba(216, 90, 48, 0.08);
        border: 1px solid rgba(216, 90, 48, 0.22);
        padding: 0.4rem 0.95rem;
        border-radius: 100px;
        margin-bottom: 1.75rem;
    }

    .hero__badge::before {
        content: '';
        width: 6px;
        height: 6px;
        background: #d85a30;
        border-radius: 50%;
        animation: hero-pulse 2s ease-in-out infinite;
    }

    @keyframes hero-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .hero h1 {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 400;
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: #0f1b2c;
        margin: 0 0 1.5rem;
    }

    .hero h1 em {
        font-style: italic;
        color: #d85a30;
    }

    .hero__subtitle {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #4a5a70;
        max-width: 640px;
        margin: 0 0 1rem;
    }

    .hero__credibility {
        font-size: 0.9rem;
        line-height: 1.5;
        color: #7a8aa0;
        margin: 0 0 2rem;
    }

    .hero__cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        align-items: center;
    }

    .hero__cta-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.9rem 1.5rem;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.3;
        color: #0f1b2c;
        background: transparent;
        border: 1.5px solid rgba(15, 27, 44, 0.22);
        border-radius: 8px;
        text-decoration: none;
        transition: background-color 0.2s, color 0.2s, transform 0.15s,
            box-shadow 0.2s, border-color 0.2s;
    }

    .hero__cta-secondary:hover {
        background: #0f1b2c;
        color: #ffffff;
        border-color: #0f1b2c;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(15, 27, 44, 0.12);
    }

    .hero__visual {
        position: relative;
        display: flex;
        justify-content: center;
        isolation: isolate;
    }

    /* Soft decorative halo behind the portrait — option (c) via radial-gradient */
    .hero__visual::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 380px;
        height: 380px;
        transform: translate(-50%, -50%);
        background: radial-gradient(
            circle,
            rgba(15, 27, 44, 0.06) 0%,
            rgba(15, 27, 44, 0) 70%
        );
        border-radius: 50%;
        z-index: -1;
        pointer-events: none;
    }

    .hero__portrait {
        width: 100%;
        max-width: 320px;
        aspect-ratio: 1 / 1;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        border: 4px solid #ffffff;
        /* Ring coral 0.4 (option a) + drop shadow */
        box-shadow:
            0 0 0 1.5px rgba(216, 90, 48, 0.4),
            0 20px 50px rgba(15, 27, 44, 0.1);
    }

    @media (max-width: 640px) {
        .hero {
            padding: 3.5rem 1.25rem 3.5rem;
        }
        .hero__portrait {
            max-width: 220px;
        }
        .hero__visual::before {
            width: 280px;
            height: 280px;
        }
    }

    /* =========================================================
       SECTION 3 — PROBLEM
       ========================================================= */
    .problem {
        background: #ffffff;
        padding: 5.5rem 2rem;
    }

    .problem__inner {
        max-width: 760px;
        margin: 0 auto;
    }

    .problem h2 {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.85rem, 3.6vw, 2.6rem);
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: -0.01em;
        color: #0f1b2c;
        margin: 0 0 2rem;
    }

    .problem__body p {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #4a5a70;
        margin: 0 0 1.25rem;
    }

    .problem__body p:last-child {
        margin-bottom: 0;
    }

    .problem__body strong {
        font-weight: 600;
        color: #0f1b2c;
    }

    @media (max-width: 640px) {
        .problem {
            padding: 3.5rem 1.25rem;
        }
        .problem__body p {
            font-size: 1rem;
        }
    }

    /* =========================================================
       SECTION 4 — SOLUTION
       ========================================================= */
    .solution {
        background: #f7f8fa;
        padding: 5.5rem 2rem;
    }

    .solution__inner {
        max-width: 1100px;
        margin: 0 auto;
    }

    .solution h2 {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.85rem, 3.6vw, 2.6rem);
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: -0.01em;
        color: #0f1b2c;
        margin: 0 0 2rem;
    }

    .solution__body {
        max-width: 760px;
    }

    .solution__body p {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #4a5a70;
        margin: 0 0 1.25rem;
    }

    .solution__body p:last-child {
        margin-bottom: 0;
    }

    .solution__body strong {
        font-weight: 600;
        color: #0f1b2c;
    }

    .solution__pillars {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
        margin-top: 3.5rem;
    }

    @media (min-width: 768px) {
        .solution__pillars {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .pillar {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.85rem;
    }

    .pillar__icon {
        width: 44px;
        height: 44px;
        color: #d85a30;
        flex: 0 0 auto;
    }

    .pillar__title {
        font-family: 'DM Serif Display', serif;
        font-size: 1.35rem;
        font-weight: 400;
        line-height: 1.25;
        letter-spacing: -0.005em;
        color: #0f1b2c;
        margin: 0;
    }

    .pillar__body {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #4a5a70;
        margin: 0;
    }

    @media (max-width: 640px) {
        .solution {
            padding: 3.5rem 1.25rem;
        }
        .solution__body p {
            font-size: 1rem;
        }
    }

    /* =========================================================
       SECTION 5 — OFFER
       ========================================================= */
    .offer {
        background: #ffffff;
        padding: 5.5rem 2rem;
    }

    .offer__inner {
        max-width: 1200px;
        margin: 0 auto;
    }

    .offer h2 {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.85rem, 3.6vw, 2.6rem);
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: -0.01em;
        color: #0f1b2c;
        margin: 0 0 2.5rem;
    }

    .offer__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        align-items: stretch;
        /* Reserve room for the "Most popular" badge that overflows above the featured card */
        padding-top: 0.75rem;
    }

    @media (min-width: 880px) {
        .offer__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 640px) {
        .offer {
            padding: 3.5rem 1.25rem;
        }
    }

    /* =========================================================
       SECTION 6 — GUARANTEE
       ========================================================= */
    .guarantee {
        background: #f7f8fa;
        padding: 5.5rem 2rem;
    }

    .guarantee__inner {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;

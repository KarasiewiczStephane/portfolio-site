---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const logoSvg = "data:image/svg+xml;base64,";

const base = import.meta.env.BASE_URL;
const allProjects = await getCollection('projects');
const featured = allProjects
    .filter(p => p.data.featured)
    .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
    title="Freelance Data Scientist — Climate Risk & ML | Skaraz Data"
    description="Freelance data scientist specializing in climate risk, geospatial analytics, and ML pipelines. 7+ years turning environmental data into business decisions."
    ogType="website"
    jsonLd={{
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "Person",
                "name": "Stéphane Karasiewicz",
                "url": "https://skarazdata.com",
                "image": "https://skarazdata.com/portrait.jpg",
                "jobTitle": "Freelance Senior Data Scientist",
                "worksFor": { "@type": "Organization", "name": "Skaraz Data" },
                "alumniOf": { "@type": "EducationalOrganization", "name": "Université de Lille" },
                "knowsAbout": ["Data Science", "Machine Learning", "Climate Risk", "Geospatial Analytics", "Python", "R"],
                "sameAs": [
                    "https://github.com/KarasiewiczStephane",
                    "https://www.linkedin.com/in/st%C3%A9phane-karasiewicz-349330112/",
                    "https://www.researchgate.net/profile/Stephane_Karasiewicz"
                ]
            },
            {
                "@type": "ProfessionalService",
                "name": "Skaraz Data",
                "url": "https://skarazdata.com",
                "image": "https://skarazdata.com/portrait.jpg",
                "description": "Freelance data science services: climate risk modeling, geospatial analytics, ML pipelines, interactive dashboards, and time-series forecasting.",
                "provider": { "@type": "Person", "name": "Stéphane Karasiewicz" },
                "areaServed": "Worldwide",
                "serviceType": ["Data Science", "Machine Learning", "Climate Risk Analytics", "Geospatial Analysis"],
                "address": { "@type": "PostalAddress", "addressLocality": "Boulogne-sur-Mer", "addressCountry": "FR" }
            },
            {
                "@type": "FAQPage",
                "mainEntity": [
                    {
                        "@type": "Question",
                        "name": "What climate risk data science services do you offer?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I build climate risk models, satellite data pipelines (Copernicus, ERA5, MODIS, Sentinel), geospatial analytics systems, and production ML infrastructure for environmental decision-making."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "What is your typical project duration and pricing?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Projects typically range from 2 to 30 days with both fixed-price and time-and-materials options. Contact me for a custom quote."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "Do you work remotely with international clients?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Yes. Based in France, I work remotely with clients worldwide across climate tech, insurtech, agriculture, and environmental consulting."
                        }
                    }
                ]
            }
        ]
    }}
>

<!-- HERO -->
<section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-content">
        <div class="hero-text">
            <div class="hero-badge">Available for new projects — Freelance</div>
            <h1>Turning Environmental Data into <em>Business Decisions</em></h1>
            <p class="hero-subtitle">
                Senior Data Scientist with 7+ years helping research institutes and enterprises build ML pipelines, interactive dashboards, and time-series models that ship. Specialized in climate risk, geospatial analytics, and forecasting.
            </p>
            <div class="hero-actions">
                <a href="https://calendly.com/skaraz_data/15-minute-meeting" target="_blank" class="btn-primary">Book a Free Discovery Call &rarr;</a>
                <a href={`${base}projects`} class="btn-secondary">See My Work</a>
            </div>
            <div class="hero-stats">
                <div class="stat-item"><span class="stat-number">7+</span><span class="stat-label">Years of Experience</span></div>
                <div class="stat-item"><span class="stat-number">Ph.D.</span><span class="stat-label">Marine Ecology</span></div>
                <div class="stat-item"><span class="stat-number">6</span><span class="stat-label">Peer-Reviewed Papers</span></div>
                <div class="stat-item"><span class="stat-number">2</span><span class="stat-label">CRAN Packages</span></div>
            </div>
        </div>
        <div class="hero-visual">
            <img src={`${base}portrait.jpg`} alt="Stéphane Karasiewicz — Freelance Senior Data Scientist specializing in climate risk and ML" class="hero-portrait">
        </div>
    </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
    <div class="trust-inner">
        <div class="trust-label">Trusted by research & industry</div>
        <div class="trust-items">
            <div class="trust-logo-only"><img src={`${base}ifremer-logo.png`} alt="IFREMER — French Institute for Ocean Science" class="trust-logo"></div>
            <div class="trust-logo-only"><img src={`${base}raincoat-logo.png`} alt="Raincoat LLC — Climate risk technology company" class="trust-logo"></div>
            <div class="trust-item">&#128230; <strong>12+ ML Projects</strong> — Delivered freelance</div>
            <div class="trust-item">&#128202; <strong>8,000+</strong> — CRAN Downloads</div>
        </div>
    </div>
</div>

<!-- SERVICES -->
<section class="services" id="services">
    <div class="section-container">
        <div class="section-label reveal">What I Do</div>
        <h2 class="section-title reveal">Data science services that<br>move your business forward</h2>
        <p class="section-desc reveal">I don't just build models — I deliver business outcomes. Every project starts with your goals and ends with measurable impact.</p>
        <div class="section-label reveal" style="margin-top: 2.5rem; margin-bottom: 1rem;">Core Expertise</div>
        <div class="services-grid services-grid-core">
            <div class="service-card service-card-core reveal">
                <div class="service-badge">Core Expertise</div>
                <div class="service-icon">&#127757;</div>
                <h3>Environmental & Geospatial Analytics</h3>
                <p>Satellite data analysis, climate risk modeling, ESG reporting, and environmental monitoring. 2TB+ satellite data management experience.</p>
                <div class="service-tags"><span>MODIS</span><span>Sentinel</span><span>NetCDF</span><span>Risk Assessment</span></div>
            </div>
            <div class="service-card service-card-core reveal">
                <div class="service-badge">Core Expertise</div>
                <div class="service-icon">&#128200;</div>
                <h3>Time-Series Modeling & Forecasting</h3>
                <p>Demand forecasting, anomaly detection, and predictive analytics. Full lifecycle from preprocessing to production deployment with LSTM, XGBoost, and Prophet.</p>
                <div class="service-tags"><span>XGBoost</span><span>LSTM</span><span>Prophet</span><span>scikit-learn</span></div>
            </div>
            <div class="service-card service-card-core reveal">
                <div class="service-badge">Core Expertise</div>
                <div class="service-icon">&#128202;</div>
                <h3>Interactive Dashboards & BI</h3>
                <p>Interactive analytics dashboards with country-level maps, KPI tracking, and real-time monitoring. 5+ production dashboards delivered.</p>
                <div class="service-tags"><span>Dash</span><span>Streamlit</span><span>Plotly</span><span>Shiny</span></div>
            </div>
        </div>
        <div class="section-label reveal" style="margin-top: 3rem; margin-bottom: 1rem;">Also Available</div>
        <div class="services-grid">
            <div class="service-card reveal">
                <div class="service-icon">&#9881;&#65039;</div>
                <h3>MLOps & Data Pipelines</h3>
                <p>End-to-end ML infrastructure: automated training, CI/CD, Docker containerization, cloud deployment, and ETL pipelines at scale.</p>
                <div class="service-tags"><span>Docker</span><span>CI/CD</span><span>PostgreSQL</span><span>REST APIs</span></div>
            </div>
            <div class="service-card reveal">
                <div class="service-icon">&#128300;</div>
                <h3>Statistical Consulting & R Packages</h3>
                <p>Advanced multivariate analysis, time-series modeling, and custom R package development. Published author on CRAN.</p>
                <div class="service-tags"><span>PCA</span><span>Time-Series</span><span>Niche Modeling</span><span>CRAN</span></div>
            </div>
            <div class="service-card reveal">
                <div class="service-icon">&#129302;</div>
                <h3>NLP & Computer Vision</h3>
                <p>Text classification, document extraction, image recognition using state-of-the-art transformer and CNN architectures.</p>
                <div class="service-tags"><span>PyTorch</span><span>Transformers</span><span>CNN</span><span>LLMs</span></div>
            </div>
        </div>
    </div>
</section>

<!-- TECH STACK -->
<section id="techstack">
    <div class="section-container">
        <div class="section-label reveal">Tech Stack</div>
        <h2 class="section-title reveal">Tools & Technologies</h2>
        <div class="techstack-tags reveal">
            <span>Python</span><span>R</span><span>scikit-learn</span><span>XGBoost</span>
            <span>TensorFlow</span><span>PyTorch</span><span>Dash</span><span>Streamlit</span>
            <span>Plotly</span><span>Shiny</span><span>Docker</span><span>PostgreSQL</span>
            <span>NetCDF</span><span>MODIS</span><span>Sentinel</span><span>Airflow</span>
            <span>FastAPI</span><span>Git</span><span>GitHub Actions</span><span>Pandas</span>
            <span>NumPy</span>
        </div>
    </div>
</section>

<!-- EXPERIENCE -->
<section id="experience">
    <div class="section-container">
        <div class="section-label reveal">Career Path</div>
        <h2 class="section-title reveal">From research to production</h2>
        <p class="section-desc reveal">A track record spanning marine research, freelance consulting, and industry ML engineering.</p>
        <div class="timeline reveal">
            <div class="tl-item current tl-merge tl-left">
                <div class="tl-dot"></div>
                <div class="tl-date">Present</div>
                <div class="tl-role">Freelance Senior Data Scientist</div>
                <div class="tl-company">Self-employed — Available for new projects</div>
            </div>

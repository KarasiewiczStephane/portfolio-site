</section>

<!-- PORTFOLIO -->
<section class="portfolio" id="portfolio">
    <div class="section-container">
        <div class="section-label reveal">Selected Work</div>
        <h2 class="section-title reveal">Projects with measurable outcomes</h2>
        <p class="section-desc reveal">Real deliverables, real impact — not just notebooks.</p>
        <div class="portfolio-grid">
            {featured.map(p => <ProjectCard project={p} />)}
        </div>
        <a href={`${base}projects/case-study-raincoat`} class="cs-banner reveal">
            <div class="cs-banner-label">Featured Case Study</div>
            <h3>Climate Risk Data Infrastructure at Raincoat LLC</h3>
            <p>End-to-end ML pipeline, 3 interactive dashboards, and automated satellite data management for parametric insurance — serving 10+ countries.</p>
            <span class="cs-banner-arrow">Read the full case study &rarr;</span>
        </a>
        <div style="text-align: center; margin-top: 2.5rem;">
            <a href={`${base}projects`} class="btn-primary">See All Projects &rarr;</a>
        </div>
    </div>
</section>

<!-- PUBLICATIONS -->

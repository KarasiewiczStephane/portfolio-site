        font-style: italic;
    }

    /* =========================================================
       SECTION 5 — Reality Check resource card
       ========================================================= */
    .cs-resource {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-top: 1.5rem;
        padding: 1.5rem 1.75rem;
